   "source": [
    "con = duckdb.connect(str(DUCKDB_PATH), read_only=True)\n",
    "\n",
    "# Nom de la commune\n",
    "nom = con.execute(\n",
    "    \"SELECT nom_commune FROM communes WHERE code_insee = ?\", [COMMUNE]\n",
    ").fetchone()\n",
    "nom_commune = nom[0] if nom else COMMUNE\n",
    "print(f\"Commune : {nom_commune} ({COMMUNE})\")\n",
    "\n",
    "# Historique risque\n",
    "hist = con.execute(\"\"\"\n",
    "    SELECT date, ift_journalier_total, indicateur_meteo,\n",
    "           interdiction_pulv, pluie_limitante, risque_dispersion,\n",
    "           wind_speed_10m_max, precipitation_sum,\n",
    "           risque_brut, risque_0_4\n",
    "    FROM risque_journalier\n",
    "    WHERE insee_com = ?\n",
    "      AND date BETWEEN ? AND ?\n",
    "    ORDER BY date\n",
    "\"\"\", [COMMUNE, DATE_DEBUT, DATE_FIN]).df()\n",
    "\n",
    "# Prévisions\n",
    "prev = con.execute(\"\"\"\n",
    "    SELECT date, ift_journalier_total, indicateur_meteo,\n",
    "           interdiction_pulv, pluie_limitante, risque_dispersion,\n",
    "           wind_speed_10m_max, precipitation_sum,\n",
    "           risque_brut, risque_0_4\n",
    "    FROM risque_previsions\n",
    "    WHERE insee_com = ?\n",
    "      AND date BETWEEN ? AND ?\n",
    "    ORDER BY date\n",
    "\"\"\", [COMMUNE, DATE_DEBUT, DATE_FIN]).df()\n",
    "\n",
    "con.close()\n",
    "\n",
    "hist[\"date\"] = pd.to_datetime(hist[\"date\"])\n",
    "prev[\"date\"] = pd.to_datetime(prev[\"date\"])\n",
    "\n",
    "print(f\"Risque historique : {len(hist)} jours  |  Prévisions : {len(prev)} jours\")\n",
    "\n",
    "# ── Mesures pesticides atmosphériques ───────────────────────────────\n",
    "_raw = pd.read_excel(\n",
    "    MESURES_PESTICIDES_FILE,\n",
    "    sheet_name='pesticides_2002_2023_v-07-2025',\n",
    "    dtype={'Code INSEE': float}\n",
    ")\n",
    "_raw['code_insee'] = _raw['Code INSEE'].dropna().astype(int).astype(str).str.zfill(5)\n",
    "_raw['Debut prelevement'] = pd.to_datetime(_raw['Debut prelevement'])\n",
    "_raw['Fin prelevement']   = pd.to_datetime(_raw['Fin prelevement'])\n",
    "\n",
    "mesures = _raw[\n",
    "    (_raw['code_insee'] == COMMUNE) &\n",
    "    (_raw['Debut prelevement'] >= DATE_DEBUT) &\n",
    "    (_raw['Fin prelevement']   <= DATE_FIN)\n",
    "].copy()\n",
    "\n",
    "mesures_det = mesures[mesures['Concentration (ng/m3)'] > 0].copy()\n",
    "\n",
    "if mesures.empty:\n",
    "    print(f\"ℹ️  Aucune mesure de pesticides pour {nom_commune} sur cette période.\")\n",
    "else:\n",
    "    n_periods   = mesures['Debut prelevement'].nunique()\n",
    "    n_subst     = mesures['Substance active'].nunique()\n",
    "    n_det_subst = mesures_det['Substance active'].nunique()\n",
    "    print(f\"Mesures : {len(mesures):,} lignes | {n_periods} périodes | \"\n",
    "          f\"{n_subst} substances analysées | {n_det_subst} détectées\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Vue d'ensemble — risque, météo, indicateurs"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "RISK_COLORS = {\n",
    "    -1: '#78909C',\n",
    "     0: '#4CAF50',\n",
    "     1: '#FFEB3B',\n",
    "     2: '#FF9800',\n",
    "     3: '#F44336',\n",
    "     4: '#B71C1C',\n",
    "}\n",
    "\n",
    "def risque_color(val):\n",
    "    if pd.isna(val): return RISK_COLORS[-1]\n",
    "    return RISK_COLORS.get(int(val), RISK_COLORS[-1])\n",
    "\n",
    "all_data = pd.concat([hist, prev], ignore_index=True).drop_duplicates('date').sort_values('date')\n",
    "is_prev  = all_data['date'].isin(prev['date'])\n",
    "mask_h   = ~is_prev\n",
    "\n",
    "has_mesures = not mesures_det.empty\n",
    "n_panels    = 5 if has_mesures else 4\n",
    "heights     = [1, 2, 2, 2, 3] if has_mesures else [1, 2, 2, 2]\n",
    "\n",
    "fig, axes = plt.subplots(\n",
    "    n_panels, 1,\n",
    "    figsize=(16, 4 + 2.5 * n_panels),\n",
    "    sharex=True,\n",
    "    gridspec_kw={'height_ratios': heights}\n",
    ")\n",
    "fig.suptitle(f\"{nom_commune} ({COMMUNE}) — {DATE_DEBUT} → {DATE_FIN}\", fontsize=13, fontweight='bold')\n",
    "\n",
    "# ── 1. Risque 0-4 ────────────────────────────────────────────────────\n",
    "ax = axes[0]\n",
    "colors = [risque_color(v) for v in all_data['risque_0_4']]\n",
    "ax.bar(all_data['date'], np.ones(len(all_data)), color=colors, width=1.0, align='center')\n",
    "if is_prev.any():\n",
    "    ax.bar(all_data.loc[is_prev, 'date'], np.ones(is_prev.sum()),\n",
    "           color='none', edgecolor='white', linewidth=0.5, width=1.0, hatch='//')\n",
    "ax.set_ylabel('Risque')\n",
    "ax.set_ylim(0, 1)\n",
    "ax.set_yticks([])\n",
    "patches = [mpatches.Patch(color=c, label=l) for c, l in\n",
    "           [('#78909C','Pas de cal.'),('#4CAF50','0'),('#FFEB3B','1'),\n",
    "            ('#FF9800','2'),('#F44336','3'),('#B71C1C','4')]]\n",
    "ax.legend(handles=patches, loc='upper left', fontsize=7, ncol=6)\n",
    "\n",
    "# ── 2. IFT journalier ───────────────────────────────────────────────\n",
    "ax = axes[1]\n",
    "ax.bar(all_data.loc[mask_h, 'date'], all_data.loc[mask_h, 'ift_journalier_total'],\n",
    "       color='#1976D2', width=1, alpha=0.85, label='Historique')\n",
    "if is_prev.any():\n",
    "    ax.bar(all_data.loc[is_prev, 'date'], all_data.loc[is_prev, 'ift_journalier_total'],\n",
    "           color='#90CAF9', width=1, alpha=0.85, label='Prévisions')\n",
    "ax.set_ylabel('IFT journalier')\n",
    "ax.legend(fontsize=8)\n",
    "\n",
    "# ── 3. Précipitations ───────────────────────────────────────────────\n",
    "ax = axes[2]\n",
    "ax.bar(all_data.loc[mask_h, 'date'], all_data.loc[mask_h, 'precipitation_sum'],\n",
    "       color='#0288D1', width=1, alpha=0.8)\n",
    "if is_prev.any():\n",
    "    ax.bar(all_data.loc[is_prev, 'date'], all_data.loc[is_prev, 'precipitation_sum'],\n",
    "           color='#81D4FA', width=1, alpha=0.8)\n",
    "pluie = all_data[all_data['pluie_limitante'] == True]\n",
    "if not pluie.empty:\n",
    "    ax.scatter(pluie['date'], pluie['precipitation_sum'], color='red', s=15, zorder=5, label='Pluie limitante')\n",
    "    ax.legend(fontsize=8)\n",
    "ax.set_ylabel('Précip. (mm)')\n",
    "\n",
    "# ── 4. Vent ──────────────────────────────────────────────────────────\n",
    "ax = axes[3]\n",
    "ax.plot(all_data.loc[mask_h, 'date'], all_data.loc[mask_h, 'wind_speed_10m_max'],\n",
    "        color='#43A047', linewidth=0.8, label='Historique')\n",
    "if is_prev.any():\n",
    "    ax.plot(all_data.loc[is_prev, 'date'], all_data.loc[is_prev, 'wind_speed_10m_max'],\n",
    "            color='#A5D6A7', linewidth=0.8, linestyle='--', label='Prévisions')\n",
    "ax.axhline(VENT_MAX, color='red',    linewidth=0.8, linestyle=':', label=f'Interdit ({VENT_MAX})')\n",
    "ax.axhline(VENT_DISPERSION_SEUIL2, color='orange', linewidth=0.8, linestyle=':', label=f'Seuil2 ({VENT_DISPERSION_SEUIL2})')\n",
    "ax.axhline(VENT_DISPERSION_MIN, color='gold', linewidth=0.8, linestyle=':', label=f'Min ({VENT_DISPERSION_MIN})')\n",
    "interdit = all_data[all_data['interdiction_pulv'] == True]\n",
    "if not interdit.empty:\n",
    "    ax.fill_between(interdit['date'], 0, all_data['wind_speed_10m_max'].max(),\n",
    "                    alpha=0.08, color='red')\n",
    "ax.set_ylabel('Vent (km/h)')\n",
    "ax.legend(fontsize=7, ncol=3)\n",
    "\n",
    "# ── 5. Mesures pesticides (si disponibles sur la période) ────────────\n",
    "if has_mesures:\n",
    "    ax = axes[4]\n",
    "    top_subst = (\n",
    "        mesures_det.groupby('Substance active')['Concentration (ng/m3)']\n",
    "        .sum().sort_values(ascending=False).head(10).index.tolist()\n",
    "    )\n",
    "    palette = plt.cm.tab10.colors\n",
    "    agg = (\n",
    "        mesures_det[mesures_det['Substance active'].isin(top_subst)]\n",
    "        .groupby(['Debut prelevement', 'Substance active'])['Concentration (ng/m3)']\n",
    "        .sum().reset_index()\n",
    "    )\n",
    "    for i, subst in enumerate(top_subst):\n",
    "        sub = agg[agg['Substance active'] == subst]\n",
    "        ax.bar(sub['Debut prelevement'], sub['Concentration (ng/m3)'],\n",
    "               width=5, color=palette[i % len(palette)], alpha=0.8, label=subst)\n",
    "    # Courbe de concentration totale en fond\n",
    "    tot = mesures_det.groupby('Debut prelevement')['Concentration (ng/m3)'].sum().reset_index()\n",
    "    ax.step(tot['Debut prelevement'], tot['Concentration (ng/m3)'],\n",
    "            color='black', linewidth=0.8, alpha=0.4, where='post', label='Total')\n",
    "    ax.set_ylabel('Conc. (ng/m³)')\n",
    "    ax.set_title('Mesures pesticides atmosphériques (AASQA) — top 10 substances', fontsize=9, loc='left')\n",
    "    ax.legend(fontsize=7, ncol=3, loc='upper right')\n",
    "\n",
    "# Formatage axe x\n",
    "axes[-1].xaxis.set_major_locator(mdates.YearLocator())\n",
    "axes[-1].xaxis.set_major_formatter(mdates.DateFormatter('%Y'))\n",
    "axes[-1].xaxis.set_minor_locator(mdates.MonthLocator(bymonth=[4, 7, 10]))\n",
    "\n",
    "today = pd.Timestamp.today().normalize()\n",
    "for ax in axes:\n",
    "    ax.axvline(today, color='black', linewidth=1, linestyle='--', alpha=0.4)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../notebooks/outputs/risque_commune.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print('Sauvegardé → outputs/risque_commune.png')"
   ]
  },
