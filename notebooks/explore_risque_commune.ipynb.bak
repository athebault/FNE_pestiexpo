    "# ── Paramètres zoom ──\n",
    "ZOOM_DEBUT = '2026-03-01'\n",
    "ZOOM_FIN   = '2026-05-15'   # inclut les prévisions\n",
    "# ─────────────────────\n",
    "\n",
    "zoom = all_data[(all_data['date'] >= ZOOM_DEBUT) & (all_data['date'] <= ZOOM_FIN)].copy()\n",
    "is_prev_zoom = zoom['date'].isin(prev['date'])\n",
    "\n",
    "mesures_zoom = mesures_det[\n",
    "    (mesures_det['Debut prelevement'] >= ZOOM_DEBUT) &\n",
    "    (mesures_det['Debut prelevement'] <= ZOOM_FIN)\n",
    "] if has_mesures else pd.DataFrame()\n",
    "\n",
    "has_mesures_zoom = not mesures_zoom.empty\n",
    "n_panels_z = 4 + (1 if has_mesures_zoom else 0)\n",
    "heights_z  = [1, 2, 2, 2] + ([3] if has_mesures_zoom else [])\n",
    "\n",
    "fig, axes = plt.subplots(n_panels_z, 1, figsize=(14, 3 + 2.2 * n_panels_z),\n",
    "                         sharex=True, gridspec_kw={'height_ratios': heights_z})\n",
    "fig.suptitle(f\"{nom_commune} — zoom {ZOOM_DEBUT} → {ZOOM_FIN}\", fontsize=12, fontweight='bold')\n",
    "\n",
    "# Risque\n",
    "ax = axes[0]\n",
    "colors_z = [risque_color(v) for v in zoom['risque_0_4']]\n",
    "ax.bar(zoom['date'], zoom['risque_0_4'].fillna(-0.3), color=colors_z, width=0.9)\n",
    "if is_prev_zoom.any():\n",
    "    ax.bar(zoom.loc[is_prev_zoom,'date'], zoom.loc[is_prev_zoom,'risque_0_4'].fillna(-0.3),\n",
    "           color='none', edgecolor='grey', linewidth=1, width=0.9, hatch='//')\n",
    "ax.set_ylabel('Risque (0-4)')\n",
    "ax.set_ylim(-0.5, 4.5)\n",
    "ax.set_yticks([0,1,2,3,4])\n",
    "\n",
    "# Précipitations\n",
    "ax = axes[1]\n",
    "ax.bar(zoom.loc[~is_prev_zoom,'date'], zoom.loc[~is_prev_zoom,'precipitation_sum'],\n",
    "       color='#0288D1', width=0.9, alpha=0.8)\n",
    "if is_prev_zoom.any():\n",
    "    ax.bar(zoom.loc[is_prev_zoom,'date'], zoom.loc[is_prev_zoom,'precipitation_sum'],\n",
    "           color='#81D4FA', width=0.9, alpha=0.8)\n",
    "ax.set_ylabel('Précip. (mm)')\n",
    "\n",
    "# Vent\n",
    "ax = axes[2]\n",
    "ax.bar(zoom.loc[~is_prev_zoom,'date'], zoom.loc[~is_prev_zoom,'wind_speed_10m_max'],\n",
    "       color='#43A047', width=0.9, alpha=0.8)\n",
    "if is_prev_zoom.any():\n",
    "    ax.bar(zoom.loc[is_prev_zoom,'date'], zoom.loc[is_prev_zoom,'wind_speed_10m_max'],\n",
    "           color='#A5D6A7', width=0.9, alpha=0.8)\n",
    "ax.axhline(VENT_MAX, color='red', linewidth=1, linestyle=':', label=f'Interdit ({VENT_MAX})')\n",
    "ax.set_ylabel('Vent (km/h)')\n",
    "ax.legend(fontsize=8)\n",
    "\n",
    "# IFT\n",
    "ax = axes[3]\n",
    "ax.bar(zoom.loc[~is_prev_zoom,'date'], zoom.loc[~is_prev_zoom,'ift_journalier_total'],\n",
    "       color='#1976D2', width=0.9, alpha=0.85)\n",
    "if is_prev_zoom.any():\n",
    "    ax.bar(zoom.loc[is_prev_zoom,'date'], zoom.loc[is_prev_zoom,'ift_journalier_total'],\n",
    "           color='#90CAF9', width=0.9, alpha=0.85)\n",
    "ax.set_ylabel('IFT journalier')\n",
    "\n",
    "# Mesures zoom (si dispo)\n",
    "if has_mesures_zoom:\n",
    "    ax = axes[4]\n",
    "    top_z = (\n",
    "        mesures_zoom.groupby('Substance active')['Concentration (ng/m3)']\n",
    "        .sum().sort_values(ascending=False).head(8).index.tolist()\n",
    "    )\n",
    "    agg_z = (\n",
    "        mesures_zoom[mesures_zoom['Substance active'].isin(top_z)]\n",
    "        .groupby(['Debut prelevement', 'Substance active'])['Concentration (ng/m3)']\n",
    "        .sum().reset_index()\n",
    "    )\n",
    "    for i, subst in enumerate(top_z):\n",
    "        s = agg_z[agg_z['Substance active'] == subst]\n",
    "        ax.bar(s['Debut prelevement'], s['Concentration (ng/m3)'],\n",
    "               width=5, color=plt.cm.tab10.colors[i % 10], alpha=0.8, label=subst)\n",
    "    ax.set_ylabel('ng/m³')\n",
    "    ax.set_title('Mesures (top 8 substances)', fontsize=9, loc='left')\n",
    "    ax.legend(fontsize=7, ncol=2)\n",
    "\n",
    "axes[-1].xaxis.set_major_locator(mdates.WeekdayLocator(byweekday=mdates.MO))\n",
    "axes[-1].xaxis.set_major_formatter(mdates.DateFormatter('%d %b'))\n",
    "plt.xticks(rotation=45, ha='right')\n",
    "\n",
    "for ax in axes:\n",
    "    ax.axvline(today, color='black', linewidth=1, linestyle='--', alpha=0.4)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
