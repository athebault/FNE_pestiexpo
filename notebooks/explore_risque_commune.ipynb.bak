    "# ── À modifier ──────────────────────────────────────────────────────\n",
    "COMMUNE    = '37031'        # code INSEE  (ex: '45234' = Orléans)\n",
    "DATE_DEBUT = '2023-01-01'   # risque disponible à partir de cette année dans la BDD\n",
    "DATE_FIN   = '2023-12-31'   # peut dépasser aujourd'hui → inclut les prévisions\n",
    "\n",
    "# Pour croiser avec les mesures (couverture 2002-2023), adapter les dates :\n",
    "# DATE_DEBUT = '2010-01-01'\n",
    "# DATE_FIN   = '2015-12-31'\n",
    "# ────────────────────────────────────────────────────────────────────"
   ]
