   "source": [
    "import os\n",
    "import sys\n",
    "from pathlib import Path\n",
    "\n",
    "# Forcer DATA_DIR avant l'import de config (prioritaire sur la variable d'env Docker)\n",
    "_ROOT = Path('./../').resolve()\n",
    "os.environ['DATA_DIR'] = str(_ROOT / 'data')\n",
    "\n",
    "sys.path.insert(0, str(_ROOT))\n",
    "\n",
    "import duckdb\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.dates as mdates\n",
    "import matplotlib.patches as mpatches\n",
    "import numpy as np\n",
    "from etl.config import DUCKDB_PATH, MESURES_PESTICIDES_FILE, VENT_MAX, VENT_DISPERSION_SEUIL2, VENT_DISPERSION_MIN\n",
    "\n",
    "print(f\"BDD : {DUCKDB_PATH}  (existe : {DUCKDB_PATH.exists()})\")"
   ]
  },
