    "    dist = hist['risque_0_4'].fillna(-1).astype(int).value_counts().sort_index()\n",
    "    total = len(hist)\n",
    "    print('--- Distribution risque_0_4 ---')\n",
    "    for k, v in dist.items():\n",
    "        print(f\"  {k:2d}  {labels.get(k,'?'):15s}  {v:4d} jours  ({100*v/total:.1f}%)\")\n",
    "    print(f\"\\n--- Météo ---\")\n",
    "    print(f\"  Jours interdiction pulvérisation : {hist['interdiction_pulv'].sum():.0f}\")\n",
    "    print(f\"  Jours pluie limitante            : {hist['pluie_limitante'].sum():.0f}\")\n",
    "    print(f\"  Jours risque dispersion          : {hist['risque_dispersion'].sum():.0f}\")\n",
    "\n",
    "if has_mesures:\n",
    "    print(f\"\\n=== Mesures pesticides — {nom_commune} ===\")\n",
    "    print(f\"  Périodes de prélèvement : {mesures['Debut prelevement'].nunique()}\")\n",
    "    print(f\"  Substances analysées    : {mesures['Substance active'].nunique()}\")\n",
    "    print(f\"  Substances détectées    : {mesures_det['Substance active'].nunique()}\")\n",
    "    print(f\"  Taux de détection       : {100*len(mesures_det)/len(mesures):.1f}%\")\n",
    "    print()\n",
    "    print('--- Top 15 substances (concentration totale ng/m³) ---')\n",
    "    top = (\n",
    "        mesures_det.groupby('Substance active')['Concentration (ng/m3)']\n",
    "        .agg(total='sum', n_periodes='count', max='max')\n",
    "        .sort_values('total', ascending=False)\n",
    "        .head(15)\n",
    "    )\n",
    "    print(top.round(2).to_string())"
   ]
