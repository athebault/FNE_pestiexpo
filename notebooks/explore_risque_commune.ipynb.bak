    "           color='#81D4FA', width=0.9, alpha=0.8, label='Précip. prévision')\n",
    "ax.set_ylabel('Précip. (mm)')\n",
    "ax.legend(fontsize=8)\n",
    "\n",
    "# Vent\n",
    "ax = axes[2]\n",
    "ax.bar(zoom.loc[~is_prev_zoom,'date'], zoom.loc[~is_prev_zoom,'wind_speed_10m_max'],\n",
    "       color='#43A047', width=0.9, alpha=0.8, label='Vent historique')\n",
    "if is_prev_zoom.any():\n",
    "    ax.bar(zoom.loc[is_prev_zoom,'date'], zoom.loc[is_prev_zoom,'wind_speed_10m_max'],\n",
