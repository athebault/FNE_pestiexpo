  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Comparaison de plusieurs communes"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Paramètres ──\n",
    "COMMUNES_COMP = ['45234', '45298', '28085']  # codes INSEE à comparer\n",
    "COMP_DEBUT    = '2026-01-01'\n",
    "COMP_FIN      = '2026-12-31'\n",
    "# ────────────────\n",
    "\n",
    "con = duckdb.connect(str(DUCKDB_PATH), read_only=True)\n",
    "\n",
    "placeholders = ', '.join(['?' for _ in COMMUNES_COMP])\n",
    "df_comp = con.execute(f\"\"\"\n",
    "    SELECT r.insee_com, c.nom_commune, r.date, r.risque_0_4, r.risque_brut,\n",
    "           r.ift_journalier_total, r.precipitation_sum, r.wind_speed_10m_max\n",
    "    FROM risque_journalier r\n",
    "    LEFT JOIN communes c ON r.insee_com = c.code_insee\n",
    "    WHERE r.insee_com IN ({placeholders})\n",
    "      AND r.date BETWEEN ? AND ?\n",
    "    ORDER BY r.date\n",
    "\"\"\", COMMUNES_COMP + [COMP_DEBUT, COMP_FIN]).df()\n",
    "\n",
    "con.close()\n",
    "df_comp['date'] = pd.to_datetime(df_comp['date'])\n",
    "\n",
    "palette = plt.cm.Set2.colors\n",
    "communes_list = df_comp['insee_com'].unique()\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(16, 5))\n",
    "for i, code in enumerate(communes_list):\n",
    "    sub = df_comp[df_comp['insee_com'] == code]\n",
    "    nom_ = sub['nom_commune'].iloc[0] if 'nom_commune' in sub.columns else code\n",
    "    ax.plot(sub['date'], sub['risque_brut'], linewidth=1, color=palette[i % len(palette)],\n",
    "            label=f\"{nom_} ({code})\")\n",
    "\n",
    "ax.axvline(today, color='black', linewidth=1, linestyle='--', alpha=0.5, label=\"Aujourd'hui\")\n",
    "ax.set_ylabel('Risque brut')\n",
    "ax.set_title(f'Comparaison risque brut — {COMP_DEBUT} → {COMP_FIN}')\n",
    "ax.xaxis.set_major_locator(mdates.MonthLocator())\n",
    "ax.xaxis.set_major_formatter(mdates.DateFormatter('%b'))\n",
    "ax.legend(fontsize=9)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  }
 ],
